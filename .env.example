# Canvas API Configuration
CANVAS_URL=https://your-school.instructure.com
CANVAS_ACCESS_TOKEN=your_canvas_api_token_here

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Analytics Configuration (Optional)
ANALYTICS_ENABLED=false
POSTHOG_API_KEY=posthog_api_key_here
POSTHOG_HOST=https://app.posthog.com

# FastMCP Logging Configuration (Production Recommended)
FASTMCP_LOG_LEVEL=WARNING
FASTMCP_MASK_ERROR_DETAILS=true
FASTMCP_RESOURCE_PREFIX_FORMAT=protocol
FASTMCP_INCLUDE_FASTMCP_META=false